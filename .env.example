# Copia este archivo a .env y ajusta los valores

# Local SQLite
DATABASE_URL=sqlite:///./dev_hub.db

# Producción PostgreSQL (Neon / Supabase)
# DATABASE_URL=postgresql+psycopg2://user:password@host/dbname

APP_NAME=Dev Hub

# true → nivel DEBUG (queries SQL visibles, más verboso)
# false → nivel INFO (solo operaciones importantes + warnings + errors)
DEBUG=false

# Clave de cifrado para contraseñas (OBLIGATORIA)
# Genera una clave nueva con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANTE: guarda esta clave en un lugar seguro. Si la pierdes, las contraseñas guardadas
# son irrecuperables. Nunca compartas ni subas esta clave a un repositorio.
ENCRYPTION_KEY=
