# Dev Hub - Plantilla de variables de entorno
# Copia este archivo a .env y ajusta los valores
# LOCAL: descomenta SQLite, comenta PostgreSQL
# PROD:  descomenta PostgreSQL, comenta SQLite

# Base de datos
# LOCAL (SQLite - sin dependencias externas)
DATABASE_URL=sqlite:///./dev_hub.db

# PROD (Supabase PostgreSQL)
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

# App
APP_NAME=Dev Hub

# DEBUG=true  -> muestra queries SQL en consola (util en local)
# DEBUG=false -> solo INFO/WARNING/ERROR (usar en prod)
DEBUG=false

# Flag Secure en las cookies. Sin definir = se infiere de DEBUG
# (False en prod, True en dev para permitir HTTP en localhost).
# En produccion SIEMPRE debe ser true. Definirlo explicitamente evita
# shippear con cookies inseguras por accidente si DEBUG quedara en true.
# COOKIE_SECURE=true

# Seguridad
# IMPORTANTE: estas claves cifran contrasenas y firman sesiones.
# Si cambias ENCRYPTION_KEY, pon la clave anterior en OLD_ENCRYPTION_KEYS
# para que las contrasenas guardadas se puedan seguir descifrando.
# Si cambias SECRET_KEY, todas las sesiones activas se invalidan.
# Genera ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Genera SECRET_KEY:     python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=
SECRET_KEY=

# Claves de cifrado anteriores, separadas por coma (opcional).
# Solo se usan para DESCIFRAR datos viejos tras rotar ENCRYPTION_KEY.
# Si ves contrasenas como "gAAAAA...", pon aqui la clave con la que se cifraron
# y corre: python scripts/reencrypt_credentials.py
OLD_ENCRYPTION_KEYS=
